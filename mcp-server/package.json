{
  "name": "@shippable/mcp-server",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-2.0-or-later",
  "type": "module",
  "bin": { "shippable-mcp-server": "./dist/index.js" },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=22.12" },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:sidecar": "rm -f ../src-tauri/binaries/shippable-mcp-aarch64-apple-darwin && bun build --compile --minify --sourcemap --target=bun-darwin-arm64 ./src/index.ts --outfile ../src-tauri/binaries/shippable-mcp-aarch64-apple-darwin",
    "build:sidecar:x64": "rm -f ../src-tauri/binaries/shippable-mcp-x86_64-apple-darwin && bun build --compile --minify --sourcemap --target=bun-darwin-x64 ./src/index.ts --outfile ../src-tauri/binaries/shippable-mcp-x86_64-apple-darwin"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  }
}
